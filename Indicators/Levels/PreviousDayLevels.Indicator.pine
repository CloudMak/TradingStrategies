//@version=6
indicator("Levels / Previous Day Levels (labels per day)", overlay=true, max_labels_count=500)

import maksim_owner/PrevDayLevels/4 as PDL

// --- Inputs
inpShowOpenClose  = input.bool(false, "Show Prev Open/Close")
inpLabelDisplayPeriodDays = input.int(60, "Label display period limit (days)", minval=1, maxval=300)

// --- RUNTIME
PDL.requireIntradayTimeframe()

// --- Features
featPrevDayOhlc = PDL.getPrevDayOHLC()

// --- Rendering
plot(featPrevDayOhlc.high, "PDH", color=color.red, linewidth=2, style=plot.style_linebr)
plot(featPrevDayOhlc.low, "PDL", color=color.green, linewidth=2, style=plot.style_linebr)
plot(inpShowOpenClose ? featPrevDayOhlc.open : na, "PDO", color=color.orange, linewidth=1, style=plot.style_linebr)
plot(inpShowOpenClose ? featPrevDayOhlc.close : na, "PDC", color=color.blue, linewidth=1, style=plot.style_linebr)

// --- Annotations
var label[] lbls = array.new_label()
PDL.drawDayLabels(lbls, featPrevDayOhlc, inpShowOpenClose, inpLabelDisplayPeriodDays)
