//@version=6
strategy("Strategy / Previous Day Levels Breakout", overlay=true, pyramiding=0, scale=scale.left, max_labels_count=500, calc_on_every_tick=true)

// ── Import library
import maksim_owner/PrevDayLevels/6 as PDL

enum TrendDirection
    Down
    Flat
    Up

enum BreakoutSignal
    None
    Long
    Short

// ── Inputs
// Enables or disables the daily trade limit, affecting whether multiple entries can occur in one day.
inpTradeOncePerDay = input.bool(false, "One trade per day")
// Requires bar close confirmation for signals, affecting when entries are considered valid.
inpUseCloseConfirm = input.bool(true, "Confirm on bar close")
// Sets ATR lookback length, affecting volatility measurement used in stops and labels.
inpAtrLen = input.int(14, "ATR Length", minval=1)
// Sets ATR stop multiplier, affecting stop-loss distance from entry.
inpAtrMult = input.float(1.2, "SL = k*ATR", minval=0.1, step=0.1)
// Sets risk-reward ratio, affecting take-profit distance relative to stop distance.
inpRr = input.float(2.0, "TP = RR*SL", minval=0.1, step=0.1)
// Sets minimum stop floor as percent of entry, affecting the minimum allowed stop distance.
inpMinStopPct = input.float(0.002, "Min stop floor (% of price)", minval=0.0, step=0.0001)
// Sets ATR-based breakout buffer fraction, affecting breakout trigger sensitivity.
inpBufferAtr = input.float(0.08, "Breakout buffer (ATR fraction)", minval=0.0, step=0.01)
inpBreakoutLookbackBars = input.int(4, "Breakout lookback bars", minval=1)
// For tests
inpPdhOverrideForTests = input.string("", "PDH override (current day)", group="For tests")
inpPdlOverrideForTests = input.string("", "PDL override (current day)", group="For tests")

// Toggles entry labels, affecting whether entry diagnostics are drawn on chart.
inpShowEntryLabels = input.bool(true, "Show entry labels", group="Visualization")
// Toggles exit labels, affecting whether close outcome diagnostics are drawn on chart.
inpShowExitLabels = input.bool(true, "Show exit labels", group="Visualization")
inpShowPrevDayLevels = input.bool(false, "Show prev day levels", group="Visualization")
inpShowModelSignalLog = input.bool(false, "Show model signal log", group="Visualization")

inpUseHTFTrendFilter = input.bool(true, "Use HTF trend filter", group="Filters")
inpHtfTrendTf = input.string("60", "HTF Trend TF", options=["30", "60", "D"], group="Filters")
inpHtfMacdFastLen = input.int(12, "HTF MACD Fast Length", minval=1, group="Filters")
inpHtfMacdSlowLen = input.int(26, "HTF MACD Slow Length", minval=1, group="Filters")
inpHtfMacdSignalLen = input.int(9, "HTF MACD Signal Length", minval=1, group="Filters")
inpApiKey = input.string("", "API Key", group="API")

// ── Helpers
f_formatPrice(x) => str.tostring(x, format.mintick)
f_formatNumber(x) => str.tostring(x, "#.####")
f_risk_stopDist(entry, atrValue, atrFactor, stopFloorPct) =>
    rawStop = atrFactor * atrValue
    floorStop = stopFloorPct > 0.0 ? entry * stopFloorPct : 0.0
    math.max(rawStop, floorStop)
f_risk_tpDistance(stopDistance, rrValue) => rrValue * stopDistance
f_feature_atr(atrLength, atrTfValue = "D") =>
    request.security(syminfo.tickerid, atrTfValue, ta.atr(atrLength)[1], barmerge.gaps_off, barmerge.lookahead_on)
f_feature_breakoutBuffer(atrValue, bufferAtrValue) => bufferAtrValue * atrValue
f_inputIsNotEmpty(rawValue) => str.length(rawValue) > 0
f_parseOptionalPrice(rawValue) =>
    f_inputIsNotEmpty(rawValue) ? str.tonumber(rawValue) : na
f_applyCurrentDayPrevLevelOverridesForTests(prevDayOhlc, pdhOverrideInput, pdlOverrideInput) =>
    resultPrevDayOhlc = prevDayOhlc
    isCurrentDayBar = year(time) == year(timenow) and month(time) == month(timenow) and dayofmonth(time) == dayofmonth(timenow)
    if isCurrentDayBar and f_inputIsNotEmpty(pdhOverrideInput)
        pdhOverride = f_parseOptionalPrice(pdhOverrideInput)
        resultPrevDayOhlc := PDL.PrevDayOHLC.new(not na(pdhOverride) ? pdhOverride : resultPrevDayOhlc.high, resultPrevDayOhlc.low, resultPrevDayOhlc.open, resultPrevDayOhlc.close)
    if isCurrentDayBar and f_inputIsNotEmpty(pdlOverrideInput)
        pdlOverride = f_parseOptionalPrice(pdlOverrideInput)
        resultPrevDayOhlc := PDL.PrevDayOHLC.new(resultPrevDayOhlc.high, not na(pdlOverride) ? pdlOverride : resultPrevDayOhlc.low, resultPrevDayOhlc.open, resultPrevDayOhlc.close)
    resultPrevDayOhlc
f_feature_htfTrend(tfValue, fastLenValue, slowLenValue, signalLenValue) =>
    htfMacdLine = request.security(syminfo.tickerid, tfValue, ta.ema(close, fastLenValue) - ta.ema(close, slowLenValue), barmerge.gaps_off, barmerge.lookahead_off)
    htfSignalLine = request.security(syminfo.tickerid, tfValue, ta.ema(ta.ema(close, fastLenValue) - ta.ema(close, slowLenValue), signalLenValue), barmerge.gaps_off, barmerge.lookahead_off)
    htfTrend = TrendDirection.Flat
    if htfMacdLine > htfSignalLine
        htfTrend := TrendDirection.Up
    else if htfMacdLine < htfSignalLine
        htfTrend := TrendDirection.Down
    htfTrend
f_model_breakoutSignal(closePrice, highLevel, lowLevel, breakoutBuffer, lookbackBars) =>
    longBreakoutLevel = highLevel + breakoutBuffer
    shortBreakoutLevel = lowLevel - breakoutBuffer
    wasBelowInLookback = ta.lowest(closePrice[1], lookbackBars) <= longBreakoutLevel
    wasAboveInLookback = ta.highest(closePrice[1], lookbackBars) >= shortBreakoutLevel
    longBreakout = closePrice > longBreakoutLevel and wasBelowInLookback
    shortBreakout = closePrice < shortBreakoutLevel and wasAboveInLookback
    breakoutSignal = BreakoutSignal.None
    if longBreakout
        breakoutSignal := BreakoutSignal.Long
    else if shortBreakout
        breakoutSignal := BreakoutSignal.Short
    breakoutSignal
// Applies HTF trend filter to current signal state.
// If filter is disabled, returns incoming signalAllowedValue unchanged.
f_model_isSignalFilteredByHtf(signalValue, signalAllowedValue, useFilterValue, htfTrendValue) =>
    signalPassesHtf = signalAllowedValue
    if useFilterValue
        if signalValue == BreakoutSignal.Long
            signalPassesHtf := signalAllowedValue and htfTrendValue == TrendDirection.Up
        else if signalValue == BreakoutSignal.Short
            signalPassesHtf := signalAllowedValue and htfTrendValue == TrendDirection.Down
        else
            signalPassesHtf := false
    signalPassesHtf
f_model_confirmedByBarstate(signalAllowedValue, requireCloseConfirm) => requireCloseConfirm ? (barstate.isconfirmed and signalAllowedValue) : signalAllowedValue
f_model_signalName(signalValue) =>
    signalValue == BreakoutSignal.Long ? "LONG" : signalValue == BreakoutSignal.Short ? "SHORT" : "NONE"
// Returns true when current bar already has an entry.
f_hasEntryOnCurrentBar(lastEntryBarIndexValue) => (not na(lastEntryBarIndexValue)) and bar_index == lastEntryBarIndexValue
f_hasEntryInLookbackWindow(lastEntryBarIndexValue, lookbackBarsValue) => (not na(lastEntryBarIndexValue)) and (bar_index - lastEntryBarIndexValue < lookbackBarsValue)
f_isEntryAllowed(canTradeValue, hasEntryOnCurrentBarValue, hasEntryInLookbackWindowValue, positionSizeValue) => canTradeValue and (not hasEntryOnCurrentBarValue) and (not hasEntryInLookbackWindowValue) and (barstate.isrealtime ? true : positionSizeValue == 0)
f_alertMessage(apiKeyValue, tickerValue, side, slPrice, tpPrice) => "{\"inpApiKey\":\"" + apiKeyValue + "\",\"ticker\":\"" + tickerValue + "\",\"side\":\"" + side + "\",\"sl\":\"" + f_formatPrice(slPrice) + "\",\"tp\":\"" + f_formatPrice(tpPrice) + "\"}"

// ── Feature Layer
featClose = close
featATR = f_feature_atr(inpAtrLen, "D")
featPrevDayOhlc = PDL.getPrevDayOHLC()
featPrevDayOhlc := f_applyCurrentDayPrevLevelOverridesForTests(featPrevDayOhlc, inpPdhOverrideForTests, inpPdlOverrideForTests)
featBreakoutBuffer = f_feature_breakoutBuffer(featATR, inpBufferAtr)
featHTFTrend = f_feature_htfTrend(inpHtfTrendTf, inpHtfMacdFastLen, inpHtfMacdSlowLen, inpHtfMacdSignalLen)

// ── One-trade-per-day gate
newDay = ta.change(time("D")) != 0
var bool tradedToday = false
if newDay
    tradedToday := false
canTrade = (not inpTradeOncePerDay) or (not tradedToday)

// ── Model Layer
modelBreakoutSignal = f_model_breakoutSignal(featClose, featPrevDayOhlc.high, featPrevDayOhlc.low, featBreakoutBuffer, inpBreakoutLookbackBars)
modelSignalAllowed = modelBreakoutSignal != BreakoutSignal.None
modelSignalAllowed := f_model_isSignalFilteredByHtf(modelBreakoutSignal, modelSignalAllowed, inpUseHTFTrendFilter, featHTFTrend)
modelSignalAllowed := f_model_confirmedByBarstate(modelSignalAllowed, inpUseCloseConfirm)

// ── Risk Management
riskLongStopDist = f_risk_stopDist(featClose, featATR, inpAtrMult, inpMinStopPct)
riskShortStopDist = f_risk_stopDist(featClose, featATR, inpAtrMult, inpMinStopPct)
riskLongSLPrice = featClose - riskLongStopDist
riskLongTPPrice = featClose + f_risk_tpDistance(riskLongStopDist, inpRr)
riskShortSLPrice = featClose + riskShortStopDist
riskShortTPPrice = featClose - f_risk_tpDistance(riskShortStopDist, inpRr)

// ── Persistent trade params (for exit labels)
var float lastEntryPrice = na
var float lastSLPrice = na
var float lastTPPrice = na
var float lastATR = na
var float lastSD = na
var string lastSide = ""
var int lastEntryBarIndex = na

// ── Entries + exits
hasEntryOnCurrentBar = f_hasEntryOnCurrentBar(lastEntryBarIndex)
hasEntryInLookbackWindow = f_hasEntryInLookbackWindow(lastEntryBarIndex, inpBreakoutLookbackBars)
isEntryAllowed = f_isEntryAllowed(canTrade, hasEntryOnCurrentBar, hasEntryInLookbackWindow, strategy.position_size)

// ── Model Signal Log (all raw model signals)
if inpShowModelSignalLog and modelBreakoutSignal != BreakoutSignal.None
    signalName = f_model_signalName(modelBreakoutSignal)
    gateText = modelSignalAllowed ? "ALLOW" : "BLOCK"
    logText = "modelBreakoutSignal=" + signalName + " | modelSignalAllowed=" + str.tostring(modelSignalAllowed) + " | gate=" + gateText + " | isEntryAllowed=" + str.tostring(isEntryAllowed) + " | hasEntryOnCurrentBar=" + str.tostring(hasEntryOnCurrentBar) + " | hasEntryInLookbackWindow=" + str.tostring(hasEntryInLookbackWindow) + " | strategy.position_size=" + f_formatNumber(strategy.position_size) + " | canTrade=" + str.tostring(canTrade) + " | inpUseCloseConfirm=" + str.tostring(inpUseCloseConfirm) + " | inpUseHTFTrendFilter=" + str.tostring(inpUseHTFTrendFilter) + " | featClose=" + f_formatPrice(featClose) + " | featPDH=" + f_formatPrice(featPrevDayOhlc.high) + " | featPDL=" + f_formatPrice(featPrevDayOhlc.low) + " | featBreakoutBuffer=" + f_formatPrice(featBreakoutBuffer)
    log.info(logText)
    
if isEntryAllowed and modelSignalAllowed
    isLongSignal = modelBreakoutSignal == BreakoutSignal.Long
    entrySide = isLongSignal ? "L" : "S"
    alertSide = isLongSignal ? "Buy" : "Sell"
    entryPrice = featClose
    stopDistance = isLongSignal ? riskLongStopDist : riskShortStopDist
    slPrice = isLongSignal ? riskLongSLPrice : riskShortSLPrice
    tpPrice = isLongSignal ? riskLongTPPrice : riskShortTPPrice
    lastEntryPrice := entryPrice
    lastSLPrice := slPrice
    lastTPPrice := tpPrice
    lastATR := featATR
    lastSD := stopDistance
    lastSide := entrySide
    lastEntryBarIndex := bar_index
    strategy.entry(entrySide, isLongSignal ? strategy.long : strategy.short)
    if barstate.isrealtime
        alert(f_alertMessage(inpApiKey, syminfo.ticker, alertSide, slPrice, tpPrice))
    strategy.exit(entrySide + "x", entrySide, stop=slPrice, limit=tpPrice)
    tradedToday := true
    if inpShowEntryLabels
        txt = (isLongSignal ? "ENTRY L\n" : "ENTRY S\n") + "Entry: " + f_formatPrice(entryPrice) + "\n" + "SL: " + f_formatPrice(slPrice) + " (dist " + f_formatPrice(stopDistance) + ")\n" + "TP: " + f_formatPrice(tpPrice) + " (RR " + f_formatNumber(inpRr) + ")\n" + "ATR(" + str.tostring(inpAtrLen) + "): " + f_formatPrice(featATR) + "\n" + "Buffer: " + f_formatPrice(featBreakoutBuffer)
        label.new(bar_index, entryPrice, txt, style=isLongSignal ? label.style_label_up : label.style_label_down, textalign=text.align_left, size=size.normal)

// ── Exit detection + success/fail labels
posNow = strategy.position_size
posPrev = strategy.position_size[1]
closedThisBar = (posPrev != 0) and (posNow == 0)
if inpShowExitLabels and closedThisBar
    wasLong = posPrev > 0
    float exitPrice = na
    reason = ""
    if wasLong
        if (not na(lastSLPrice)) and (low <= lastSLPrice)
            exitPrice := lastSLPrice
            reason := "SL"
        else if (not na(lastTPPrice)) and (high >= lastTPPrice)
            exitPrice := lastTPPrice
            reason := "TP"
        else
            exitPrice := close
            reason := "Close"
    else
        if (not na(lastSLPrice)) and (high >= lastSLPrice)
            exitPrice := lastSLPrice
            reason := "SL"
        else if (not na(lastTPPrice)) and (low <= lastTPPrice)
            exitPrice := lastTPPrice
            reason := "TP"
        else
            exitPrice := close
            reason := "Close"
    win = reason == "TP"
    loss = reason == "SL"
    qty = math.abs(posPrev)
    float notional = na
    notional := not na(lastEntryPrice) ? qty * lastEntryPrice : na
    float pnl = na
    if (not na(lastEntryPrice)) and (not na(exitPrice))
        pnl := (wasLong ? (exitPrice - lastEntryPrice) : (lastEntryPrice - exitPrice)) * qty
    head = win ? "WIN ✅" : loss ? "LOSS ❌" : "CLOSED"
    txt = head + " (" + reason + ")\n" + "Side: " + (wasLong ? "L" : "S") + "\n" + "Entry: " + f_formatPrice(lastEntryPrice) + "\n" + "Exit: " + f_formatPrice(exitPrice) + "\n" + "SL: " + f_formatPrice(lastSLPrice) + "\n" + "TP: " + f_formatPrice(lastTPPrice) + "\n" + "ATR: " + f_formatPrice(lastATR) + "\n" + "StopDist: " + f_formatPrice(lastSD) + "\n" + "Qty: " + f_formatNumber(qty) + (not na(notional) ? ("\nNotional: " + f_formatNumber(notional)) : "") + (not na(pnl) ? ("\nPnL(est): " + f_formatNumber(pnl)) : "")
    label.new(bar_index, exitPrice, txt, style=label.style_label_left, textalign=text.align_left, size=size.normal)

// ── Optional: show previous day levels
plot(inpShowPrevDayLevels ? featPrevDayOhlc.high : na, "PDH", color=color.red, linewidth=2, style=plot.style_linebr)
plot(inpShowPrevDayLevels ? featPrevDayOhlc.low : na, "PDL", color=color.green, linewidth=2, style=plot.style_linebr)
plot(inpShowPrevDayLevels ? featPrevDayOhlc.high + featBreakoutBuffer : na, "PDH + ATR Buffer", color=color.new(#fff200, 35), linewidth=1, style=plot.style_linebr)
plot(inpShowPrevDayLevels ? featPrevDayOhlc.low - featBreakoutBuffer : na, "PDL - ATR Buffer", color=color.new(#3aaf00, 35), linewidth=1, style=plot.style_linebr)

// ── Optional: show previous day labels (same as indicator)
var label[] prevDayLevelLabels = array.new_label()
if inpShowPrevDayLevels
    PDL.drawDayLabels(prevDayLevelLabels, featPrevDayOhlc, false, 60)
else
    while array.size(prevDayLevelLabels) > 0
        label.delete(array.shift(prevDayLevelLabels))
