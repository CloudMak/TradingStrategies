//@version=6
library("PrevDayLevels", overlay=false, dynamic_requests=true)

// --- Core Types
export type PrevDayOHLC
    float high
    float low
    float open
    float close

// --- Core Data API
// Returns previous day OHLC computed from the exchange daily timeframe.
// lookahead_on + [1] => previous closed day values without repaint.
export getPrevDayOHLC(string tickerId = syminfo.tickerid) =>
    float prevHigh  = request.security(tickerId, "D", high[1],  barmerge.gaps_off, barmerge.lookahead_on)
    float prevLow   = request.security(tickerId, "D", low[1],   barmerge.gaps_off, barmerge.lookahead_on)
    float prevOpen  = request.security(tickerId, "D", open[1],  barmerge.gaps_off, barmerge.lookahead_on)
    float prevClose = request.security(tickerId, "D", close[1], barmerge.gaps_off, barmerge.lookahead_on)

    PrevDayOHLC.new(prevHigh, prevLow, prevOpen, prevClose)

export getPrevDayRange(string tickerId = syminfo.tickerid) =>
    prevDay = getPrevDayOHLC(tickerId)
    math.max(prevDay.high - prevDay.low, syminfo.mintick)

// Moscow timezone used to map bars to MOEX trading dates regardless of user local time.
const string MOEX_FORTS_TIMEZONE = "Europe/Moscow"
// Weekday FORTS trading day treated as one continuous session to avoid splitting on clearing breaks.
const string MOEX_FORTS_WEEKDAY_SESSION = "0850-2350:12345"
// Weekend FORTS session used when exchange provides special Saturday/Sunday trading.
const string MOEX_FORTS_WEEKEND_SESSION = "0950-1900:67"
// Official weekday FORTS session start in Moscow time. Bars starting at 08:50 belong to a new trading day.
const int MOEX_FORTS_WEEKDAY_START_HOUR = 8
const int MOEX_FORTS_WEEKDAY_START_MINUTE = 50
// Official weekend FORTS session start in Moscow time. Bars starting at 09:50 belong to a new trading day.
const int MOEX_FORTS_WEEKEND_START_HOUR = 9
const int MOEX_FORTS_WEEKEND_START_MINUTE = 50
// Official weekday FORTS session end in Moscow time.
const int MOEX_FORTS_WEEKDAY_END_HOUR = 23
const int MOEX_FORTS_WEEKDAY_END_MINUTE = 50
// Official weekend FORTS session end in Moscow time.
const int MOEX_FORTS_WEEKEND_END_HOUR = 19
const int MOEX_FORTS_WEEKEND_END_MINUTE = 0

f_isWeekendDay(int sourceTime, string timezoneValue) =>
    sourceDayOfWeek = dayofweek(sourceTime, timezoneValue)
    sourceDayOfWeek == dayofweek.saturday or sourceDayOfWeek == dayofweek.sunday

f_getTradingDayKey(int sourceTime, string timezoneValue) =>
    year(sourceTime, timezoneValue) * 10000 + month(sourceTime, timezoneValue) * 100 + dayofmonth(sourceTime, timezoneValue)

f_getMoexFortsSession() =>
    isWeekend = f_isWeekendDay(time, MOEX_FORTS_TIMEZONE)
    isWeekend ? MOEX_FORTS_WEEKEND_SESSION : MOEX_FORTS_WEEKDAY_SESSION

f_getMoexFortsSessionStartTimestamp(int sourceTime, string timezoneValue) =>
    isWeekendDay = f_isWeekendDay(sourceTime, timezoneValue)
    startHour = isWeekendDay ? MOEX_FORTS_WEEKEND_START_HOUR : MOEX_FORTS_WEEKDAY_START_HOUR
    startMinute = isWeekendDay ? MOEX_FORTS_WEEKEND_START_MINUTE : MOEX_FORTS_WEEKDAY_START_MINUTE
    timestamp(timezoneValue, year(sourceTime, timezoneValue), month(sourceTime, timezoneValue), dayofmonth(sourceTime, timezoneValue), startHour, startMinute)

f_getMoexFortsSessionEndTimestamp(int sourceTime, string timezoneValue) =>
    isWeekendDay = f_isWeekendDay(sourceTime, timezoneValue)
    endHour = isWeekendDay ? MOEX_FORTS_WEEKEND_END_HOUR : MOEX_FORTS_WEEKDAY_END_HOUR
    endMinute = isWeekendDay ? MOEX_FORTS_WEEKEND_END_MINUTE : MOEX_FORTS_WEEKDAY_END_MINUTE
    timestamp(timezoneValue, year(sourceTime, timezoneValue), month(sourceTime, timezoneValue), dayofmonth(sourceTime, timezoneValue), endHour, endMinute)

f_doTimeRangesOverlap(int startA, int endA, int startB, int endB) =>
    startA < endB and startB < endA

f_isInSession(string timezoneValue) =>
    sessionStartTimestamp = f_getMoexFortsSessionStartTimestamp(time, timezoneValue)
    sessionEndTimestamp = f_getMoexFortsSessionEndTimestamp(time, timezoneValue)
    f_doTimeRangesOverlap(time, time_close, sessionStartTimestamp, sessionEndTimestamp)

f_isMoexFortsSessionStartBar(string timezoneValue) =>
    barStartTimestamp = f_getMoexFortsSessionStartTimestamp(time, timezoneValue)
    time <= barStartTimestamp and barStartTimestamp <= time_close

export isNewMoexFortsTradingDay(string timezoneValue = "Europe/Moscow") =>
    inSession = f_isInSession(timezoneValue)
    isSessionStartBar = f_isMoexFortsSessionStartBar(timezoneValue)
    tradingDayKey = inSession ? f_getTradingDayKey(time, timezoneValue) : na
    previousTradingDayKey = nz(tradingDayKey[1], tradingDayKey)
    inSession and (isSessionStartBar or tradingDayKey != previousTradingDayKey)

// Returns previous OHLC for a MOEX FORTS trading day defined by session boundaries.
// Weekdays: 08:50-23:50 Moscow time as one continuous trading day.
// Weekend session: 09:50-19:00 Moscow time.
// The rollover is tied to the trading date in Moscow timezone, not to calendar D-bars.
export getPrevDayOhlcForMoexForts(string timezoneValue = "Europe/Moscow") =>
    inSession = f_isInSession(timezoneValue)
    newTradingDay = isNewMoexFortsTradingDay(timezoneValue)

    var float currentOpen = na
    var float currentHigh = na
    var float currentLow = na
    var float currentClose = na

    var float previousOpen = na
    var float previousHigh = na
    var float previousLow = na
    var float previousClose = na

    if newTradingDay
        if not na(currentOpen)
            previousOpen := currentOpen
            previousHigh := currentHigh
            previousLow := currentLow
            previousClose := currentClose

        currentOpen := open
        currentHigh := high
        currentLow := low
        currentClose := close
    else if inSession
        currentOpen := na(currentOpen) ? open : currentOpen
        currentHigh := na(currentHigh) ? high : math.max(currentHigh, high)
        currentLow := na(currentLow) ? low : math.min(currentLow, low)
        currentClose := close

    PrevDayOHLC.new(previousHigh, previousLow, previousOpen, previousClose)

// --- Indicator API: Previous Day Levels with labels per day

f_drawLevelLabel(label[] labels, float price, string lineTitle, color bgColor, textSize) =>
    labelText = str.format("{0} {1}", lineTitle, str.tostring(price, format.mintick))
    newLabel = label.new(
         bar_index,
         price,
         labelText,
         xloc=xloc.bar_index,
         yloc=yloc.price,
         style=label.style_label_lower_left,
         textcolor=color.white,
         color=bgColor,
         size=textSize
     )
    array.push(labels, newLabel)

export drawDayLabels(label[] labels, PrevDayOHLC prevDayOhlc, bool showOpenClose, int labelDisplayPeriodDays) =>
    newDay = ta.change(time("D")) != 0
    if newDay
        f_drawLevelLabel(labels, prevDayOhlc.high, "PDH", color.new(color.red, 0), size.normal)
        f_drawLevelLabel(labels, prevDayOhlc.low, "PDL", color.new(color.green, 0), size.normal)

        if showOpenClose
            f_drawLevelLabel(labels, prevDayOhlc.open, "PDO", color.new(color.orange, 0), size.tiny)
            f_drawLevelLabel(labels, prevDayOhlc.close, "PDC", color.new(color.blue, 0), size.tiny)

        maxLabels = labelDisplayPeriodDays * (showOpenClose ? 4 : 2)
        while array.size(labels) > maxLabels
            label.delete(array.shift(labels))

export drawMoexFortsDayLabels(label[] labels, PrevDayOHLC prevDayOhlc, bool showOpenClose, int labelDisplayPeriodDays, string timezoneValue = "Europe/Moscow") =>
    newTradingDay = isNewMoexFortsTradingDay(timezoneValue)
    if newTradingDay
        f_drawLevelLabel(labels, prevDayOhlc.high, "PDH", color.new(color.red, 0), size.normal)
        f_drawLevelLabel(labels, prevDayOhlc.low, "PDL", color.new(color.green, 0), size.normal)

        if showOpenClose
            f_drawLevelLabel(labels, prevDayOhlc.open, "PDO", color.new(color.orange, 0), size.tiny)
            f_drawLevelLabel(labels, prevDayOhlc.close, "PDC", color.new(color.blue, 0), size.tiny)

        maxLabels = labelDisplayPeriodDays * (showOpenClose ? 4 : 2)
        while array.size(labels) > maxLabels
            label.delete(array.shift(labels))

export requireIntradayTimeframe() =>
    if not timeframe.isintraday
        runtime.error("Works only on timeframes below 1D")
