//@version=6
strategy("Strategy / PDH/PDL Breakout (labels)", overlay=true, pyramiding=0, scale=scale.right, max_labels_count=500)

// ── Import library
import maksim_owner/PrevDayLevels/1 as PDL

enum TrendDirection
    Down
    Flat
    Up

// ── Inputs
// Enables or disables the daily trade limit, affecting whether multiple entries can occur in one day.
tradeOncePerDay = input.bool(true, "One trade per day")
// Requires bar close confirmation for signals, affecting when entries are considered valid.
useCloseConfirm = input.bool(true, "Confirm on bar close")
// Sets ATR lookback length, affecting volatility measurement used in stops and labels.
atrLen = input.int(14, "ATR Length", minval=1)
// Sets ATR stop multiplier, affecting stop-loss distance from entry.
atrMult = input.float(1.2, "SL = k*ATR", minval=0.1, step=0.1)
// Sets risk-reward ratio, affecting take-profit distance relative to stop distance.
rr = input.float(2.0, "TP = RR*SL", minval=0.1, step=0.1)
// Sets minimum stop floor as percent of entry, affecting the minimum allowed stop distance.
minStopPct = input.float(0.002, "Min stop floor (% of price)", minval=0.0, step=0.0001)
// Sets ATR-based breakout buffer fraction, affecting breakout trigger sensitivity.
bufferAtr = input.float(0.08, "Breakout buffer (ATR fraction)", minval=0.0, step=0.01)
breakoutLookbackBars = input.int(4, "Breakout lookback bars", minval=1)
// Toggles entry labels, affecting whether entry diagnostics are drawn on chart.
showEntryLabels = input.bool(true, "Show entry labels")
// Toggles exit labels, affecting whether close outcome diagnostics are drawn on chart.
showExitLabels = input.bool(true, "Show exit labels")
useHTFTrendFilter = input.bool(true, "Use HTF trend filter")
htfTrendTf = input.string("60", "HTF Trend TF", options=["30", "60", "D"])
htfMacdFastLen = input.int(12, "HTF MACD Fast Length", minval=1)
htfMacdSlowLen = input.int(26, "HTF MACD Slow Length", minval=1)
htfMacdSignalLen = input.int(9, "HTF MACD Signal Length", minval=1)
apiKey = input.string("", "API Key")

// ── Helpers
f_price(x) => str.tostring(x, format.mintick)
f_num(x) => str.tostring(x, "#.####")
f_risk_stopDist(entry, atrValue, atrFactor, stopFloorPct) =>
    rawStop = atrFactor * atrValue
    floorStop = stopFloorPct > 0.0 ? entry * stopFloorPct : 0.0
    math.max(rawStop, floorStop)
f_risk_tpDistance(stopDistance, rrValue) => rrValue * stopDistance
f_feature_atr(atrLength) => ta.atr(atrLength)
f_feature_breakoutBuffer(atrValue, bufferAtrValue) => bufferAtrValue * atrValue
f_feature_htfTrend(tfValue, fastLenValue, slowLenValue, signalLenValue) =>
    htfMacdLine = request.security(syminfo.tickerid, tfValue, ta.ema(close, fastLenValue) - ta.ema(close, slowLenValue), barmerge.gaps_off, barmerge.lookahead_off)
    htfSignalLine = request.security(syminfo.tickerid, tfValue, ta.ema(ta.ema(close, fastLenValue) - ta.ema(close, slowLenValue), signalLenValue), barmerge.gaps_off, barmerge.lookahead_off)
    htfTrend = TrendDirection.Flat
    if htfMacdLine > htfSignalLine
        htfTrend := TrendDirection.Up
    else if htfMacdLine < htfSignalLine
        htfTrend := TrendDirection.Down
    htfTrend
f_model_longBreakout(closePrice, level, breakoutBuffer, lookbackBars) =>
    breakoutLevel = level + breakoutBuffer
    wasBelowInLookback = ta.lowest(closePrice[1], lookbackBars) <= breakoutLevel
    closePrice > breakoutLevel and wasBelowInLookback
f_model_shortBreakout(closePrice, level, breakoutBuffer, lookbackBars) =>
    breakoutLevel = level - breakoutBuffer
    wasAboveInLookback = ta.highest(closePrice[1], lookbackBars) >= breakoutLevel
    closePrice < breakoutLevel and wasAboveInLookback
f_model_confirmed(rawSignal, requireCloseConfirm) => requireCloseConfirm ? (barstate.isconfirmed and rawSignal) : rawSignal
// Returns true when current bar already has an entry.
f_hasEntryOnCurrentBar(lastEntryBarValue) => (not na(lastEntryBarValue)) and bar_index == lastEntryBarValue
f_alertMessage(apiKeyValue, tickerValue, side, slPrice, tpPrice) => "{\"apiKey\":\"" + apiKeyValue + "\",\"ticker\":\"" + tickerValue + "\",\"side\":\"" + side + "\",\"sl\":\"" + f_price(slPrice) + "\",\"tp\":\"" + f_price(tpPrice) + "\"}"

// ── Feature Layer
featClose = close
featATR = f_feature_atr(atrLen)
[featPrevHighPrice, featPrevLowPrice, _, _] = PDL.getPrevDayOHLC()
featBreakoutBuffer = f_feature_breakoutBuffer(featATR, bufferAtr)
featHTFTrend = f_feature_htfTrend(htfTrendTf, htfMacdFastLen, htfMacdSlowLen, htfMacdSignalLen)

// ── One-trade-per-day gate
newDay = ta.change(time("D")) != 0
var bool tradedToday = false
if newDay
    tradedToday := false
canTrade = (not tradeOncePerDay) or (not tradedToday)

// ── Model Layer
modelLongCondRaw = f_model_longBreakout(featClose, featPrevHighPrice, featBreakoutBuffer, breakoutLookbackBars)
modelShortCondRaw = f_model_shortBreakout(featClose, featPrevLowPrice, featBreakoutBuffer, breakoutLookbackBars)
modelLongTrendPass = (not useHTFTrendFilter) or featHTFTrend == TrendDirection.Up
modelShortTrendPass = (not useHTFTrendFilter) or featHTFTrend == TrendDirection.Down
modelLongCond = f_model_confirmed(modelLongCondRaw and modelLongTrendPass, useCloseConfirm)
modelShortCond = f_model_confirmed(modelShortCondRaw and modelShortTrendPass, useCloseConfirm)

// ── Risk Management
riskLongStopDist = f_risk_stopDist(featClose, featATR, atrMult, minStopPct)
riskShortStopDist = f_risk_stopDist(featClose, featATR, atrMult, minStopPct)
riskLongSLPrice = featClose - riskLongStopDist
riskLongTPPrice = featClose + f_risk_tpDistance(riskLongStopDist, rr)
riskShortSLPrice = featClose + riskShortStopDist
riskShortTPPrice = featClose - f_risk_tpDistance(riskShortStopDist, rr)

// ── Persistent trade params (for exit labels)
var float lastEntryPrice = na
var float lastSLPrice = na
var float lastTPPrice = na
var float lastATR = na
var float lastSD = na
var string lastSide = ""
var int lastEntryBar = na

// ── Entries + exits
hasEntryOnCurrentBar = f_hasEntryOnCurrentBar(lastEntryBar)
isEntryAllowed = canTrade and strategy.position_size == 0 and (not hasEntryOnCurrentBar)
if isEntryAllowed
    if modelLongCond
        entryPrice = featClose
        sd = riskLongStopDist
        slPrice = riskLongSLPrice
        tpPrice = riskLongTPPrice
        lastEntryPrice := entryPrice
        lastSLPrice := slPrice
        lastTPPrice := tpPrice
        lastATR := featATR
        lastSD := sd
        lastSide := "L"
        lastEntryBar := bar_index
        strategy.entry("L", strategy.long)
        if barstate.isrealtime
            alert(f_alertMessage(apiKey, syminfo.ticker, "Buy", slPrice, tpPrice))
        strategy.exit("Lx", "L", stop=slPrice, limit=tpPrice)
        tradedToday := true
        if showEntryLabels
            txt = "ENTRY L\n" + "Entry: " + f_price(entryPrice) + "\n" + "SL: " + f_price(slPrice) + " (dist " + f_price(sd) + ")\n" + "TP: " + f_price(tpPrice) + " (RR " + f_num(rr) + ")\n" + "ATR(" + str.tostring(atrLen) + "): " + f_price(featATR) + "\n" + "Buffer: " + f_price(featBreakoutBuffer)
            label.new(bar_index, entryPrice, txt, style=label.style_label_up, textalign=text.align_left, size=size.normal)
    if modelShortCond
        entryPrice = featClose
        sd = riskShortStopDist
        slPrice = riskShortSLPrice
        tpPrice = riskShortTPPrice
        lastEntryPrice := entryPrice
        lastSLPrice := slPrice
        lastTPPrice := tpPrice
        lastATR := featATR
        lastSD := sd
        lastSide := "S"
        lastEntryBar := bar_index
        strategy.entry("S", strategy.short)
        if barstate.isrealtime
            alert(f_alertMessage(apiKey, syminfo.ticker, "Sell", slPrice, tpPrice))
        strategy.exit("Sx", "S", stop=slPrice, limit=tpPrice)
        tradedToday := true
        if showEntryLabels
            txt = "ENTRY S\n" + "Entry: " + f_price(entryPrice) + "\n" + "SL: " + f_price(slPrice) + " (dist " + f_price(sd) + ")\n" + "TP: " + f_price(tpPrice) + " (RR " + f_num(rr) + ")\n" + "ATR(" + str.tostring(atrLen) + "): " + f_price(featATR) + "\n" + "Buffer: " + f_price(featBreakoutBuffer)
            label.new(bar_index, entryPrice, txt, style=label.style_label_down, textalign=text.align_left, size=size.normal)

// ── Exit detection + success/fail labels
posNow = strategy.position_size
posPrev = strategy.position_size[1]
closedThisBar = (posPrev != 0) and (posNow == 0)
if showExitLabels and closedThisBar
    wasLong = posPrev > 0
    float exitPrice = na
    reason = ""
    if wasLong
        if (not na(lastSLPrice)) and (low <= lastSLPrice)
            exitPrice := lastSLPrice
            reason := "SL"
        else if (not na(lastTPPrice)) and (high >= lastTPPrice)
            exitPrice := lastTPPrice
            reason := "TP"
        else
            exitPrice := close
            reason := "Close"
    else
        if (not na(lastSLPrice)) and (high >= lastSLPrice)
            exitPrice := lastSLPrice
            reason := "SL"
        else if (not na(lastTPPrice)) and (low <= lastTPPrice)
            exitPrice := lastTPPrice
            reason := "TP"
        else
            exitPrice := close
            reason := "Close"
    win = reason == "TP"
    loss = reason == "SL"
    qty = math.abs(posPrev)
    float notional = na
    notional := not na(lastEntryPrice) ? qty * lastEntryPrice : na
    float pnl = na
    if (not na(lastEntryPrice)) and (not na(exitPrice))
        pnl := (wasLong ? (exitPrice - lastEntryPrice) : (lastEntryPrice - exitPrice)) * qty
    head = win ? "WIN ✅" : loss ? "LOSS ❌" : "CLOSED"
    txt = head + " (" + reason + ")\n" + "Side: " + (wasLong ? "L" : "S") + "\n" + "Entry: " + f_price(lastEntryPrice) + "\n" + "Exit: " + f_price(exitPrice) + "\n" + "SL: " + f_price(lastSLPrice) + "\n" + "TP: " + f_price(lastTPPrice) + "\n" + "ATR: " + f_price(lastATR) + "\n" + "StopDist: " + f_price(lastSD) + "\n" + "Qty: " + f_num(qty) + (not na(notional) ? ("\nNotional: " + f_num(notional)) : "") + (not na(pnl) ? ("\nPnL(est): " + f_num(pnl)) : "")
    label.new(bar_index, exitPrice, txt, style=label.style_label_left, textalign=text.align_left, size=size.normal)

// ── Optional: show PDH/PDL lines
// plot(featPrevHighPrice, "PDH", linewidth=2, style=plot.style_linebr)
// plot(featPrevLowPrice, "PDL", linewidth=2, style=plot.style_linebr)

// ── Optional: show PDH/PDL lines (if you want)
// plot(featPrevHighPrice, "PDH", linewidth=2, style=plot.style_linebr)
// plot(featPrevLowPrice,  "PDL", linewidth=2, style=plot.style_linebr)
